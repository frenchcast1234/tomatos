{
  "editor.gpuAcceleration": "on",
  "files.watcherExclude": {
    "**/build/**": true,
    "**/.dart_tool/**": true,
    "**/node_modules/**": true
  },
  "files.exclude": {
    "**/build": true,
    "**/.dart_tool": true
  },
  "editor.renderWhitespace": "none",
  "editor.minimap.enabled": false,
  "editor.wordWrap": "off",
  "search.followSymlinks": false
}